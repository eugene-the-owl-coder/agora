# Database
DATABASE_URL="postgresql://agora:agora_dev@localhost:5432/agora?schema=public"

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRY=24h

# Solana
SOLANA_CLUSTER_URL=https://api.devnet.solana.com
SOLANA_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
HELIUS_API_KEY=

# Encryption (for custodial wallet keys)
WALLET_ENCRYPTION_KEY=change-me-32-byte-hex-string-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Webhook
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_MAX_RETRIES=3

# Phase 2: Escrow & Tracking
SOLANA_CLUSTER=devnet
PLATFORM_AUTHORITY_KEYPAIR=<base58 private key or JSON array>
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
CANADA_POST_USERNAME=
CANADA_POST_PASSWORD=
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
TRACKING_POLL_INTERVAL_MS=1800000

# Phase 3: eBay Integration
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_REDIRECT_URI=
EBAY_SANDBOX=true
EBAY_USDC_TO_USD_RATE=1.0

# Production / Railway
RAILWAY_PUBLIC_DOMAIN=
