generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id                 String   @id @default(uuid())
  name               String
  email              String   @unique
  apiKeyHash         String
  apiKeyPrefix       String
  walletAddress      String?
  walletEncryptedKey String?
  profileDescription String?
  avatarUrl          String?
  reputation         Float    @default(0)
  buyerRating        Float?                // null = N/A (no transactions as buyer)
  sellerRating       Float?                // null = N/A (no transactions as seller)
  buyerTxCount       Int      @default(0)
  sellerTxCount      Int      @default(0)
  lastTransactionAt  DateTime?
  totalSales         Int      @default(0)
  totalPurchases     Int      @default(0)
  isVerified         Boolean  @default(false)
  operatorId         String?
  permissions        Json     @default("[\"list\", \"buy\", \"sell\"]")
  spendingLimits     Json     @default("{\"maxPerTx\": 1000000000, \"dailyCap\": 10000000000}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  operator          Agent?          @relation("AgentOperator", fields: [operatorId], references: [id])
  subAgents         Agent[]         @relation("AgentOperator")
  listings          Listing[]
  buyOrders         Order[]         @relation("BuyerOrders")
  sellOrders        Order[]         @relation("SellerOrders")
  sentTransactions  Transaction[]   @relation("FromAgent")
  receivedTransactions Transaction[] @relation("ToAgent")
  webhooks          Webhook[]
  featureRequests   FeatureRequest[]
  persistentBuyOrders BuyOrder[]
  marketplaceCredentials MarketplaceCredential[]
  openedDisputes    Dispute[]         @relation("DisputeOpener")
  resolvedDisputes  Dispute[]         @relation("DisputeResolver")
  submittedEvidence DisputeEvidence[] @relation("EvidenceSubmitter")
  negotiationsAsBuyer  Negotiation[]        @relation("NegotiationBuyer")
  negotiationsAsSeller Negotiation[]        @relation("NegotiationSeller")
  negotiationMessages  NegotiationMessage[]
  spendingPolicy       SpendingPolicy?
  events               Event[]
  wallets              UserWallet[]

  @@index([apiKeyPrefix])
  @@index([walletAddress])
  @@index([email])
}

enum ListingCondition {
  new
  like_new
  good
  fair
  poor
}

enum ListingStatus {
  draft
  active
  sold
  delisted
  disputed
}

model Listing {
  id               String           @id @default(uuid())
  agentId          String
  title            String
  description      String
  images           String[]
  priceUsdc        BigInt
  priceSol         BigInt?
  category         String
  condition        ListingCondition @default(new)
  status           ListingStatus    @default(draft)
  quantity         Int              @default(1)
  metadata             Json             @default("{}")
  externalListings     Json             @default("{}")
  minimumBuyerRating   Float?           // Seller can require minimum buyer rating
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  agent            Agent            @relation(fields: [agentId], references: [id])
  orders           Order[]
  matchedBuyOrders BuyOrder[]       @relation("MatchedListing")
  syndicationRecords SyndicationRecord[]
  negotiations     Negotiation[]

  @@index([agentId])
  @@index([category])
  @@index([status])
  @@index([priceUsdc])
}

enum OrderStatus {
  pending_approval
  created
  funded
  fulfilled
  completed
  disputed
  cancelled
  refunded
}

enum FulfillmentType {
  shipped
  local_meetup
}

enum MeetupStatus {
  scheduled
  seller_handed_over
  buyer_confirmed
  expired
}

model Order {
  id              String      @id @default(uuid())
  listingId       String
  buyerAgentId    String
  sellerAgentId   String
  amountUsdc      BigInt
  escrowAddress   String?
  escrowSignature String?
  status          OrderStatus @default(created)
  shippingInfo    Json?
  trackingNumber  String?
  carrier         String?
  tier            Int         @default(1)
  buyerCollateralUsdc   BigInt?
  sellerCollateralUsdc  BigInt?
  collateralRatio       Float?    @default(1.0)
  fulfillmentType      FulfillmentType @default(shipped)
  meetupTime           DateTime?
  meetupArea           String?
  meetupStatus         MeetupStatus?
  handedOverAt         DateTime?
  coolingPeriodEndsAt  DateTime?
  sellerReleaseWallet  String?   // snapshot at order creation
  buyerRefundWallet    String?   // snapshot at order creation
  disputeReason   String?
  deliveredAt     DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  listing         Listing        @relation(fields: [listingId], references: [id])
  buyer           Agent          @relation("BuyerOrders", fields: [buyerAgentId], references: [id])
  seller          Agent          @relation("SellerOrders", fields: [sellerAgentId], references: [id])
  transactions    Transaction[]
  trackingEvents  TrackingEvent[]
  dispute         Dispute?

  @@index([buyerAgentId])
  @@index([sellerAgentId])
  @@index([status])
}

enum TxType {
  escrow_fund
  escrow_release
  refund
  withdrawal
  deposit
}

enum TxStatus {
  pending
  confirmed
  failed
}

model Transaction {
  id          String   @id @default(uuid())
  orderId     String?
  fromAgentId String?
  toAgentId   String?
  amountUsdc  BigInt?
  amountSol   BigInt?
  txSignature String?
  txType      TxType
  status      TxStatus @default(pending)
  createdAt   DateTime @default(now())

  order     Order? @relation(fields: [orderId], references: [id])
  fromAgent Agent? @relation("FromAgent", fields: [fromAgentId], references: [id])
  toAgent   Agent? @relation("ToAgent", fields: [toAgentId], references: [id])

  @@index([orderId])
  @@index([txSignature])
}

model Webhook {
  id       String   @id @default(uuid())
  agentId  String
  url      String
  events   String[]
  secret   String
  isActive Boolean  @default(true)
  createdAt DateTime @default(now())

  agent    Agent    @relation(fields: [agentId], references: [id])

  @@index([agentId])
}

enum FeatureRequestStatus {
  open
  planned
  building
  shipped
  rejected
}

model FeatureRequest {
  id          String               @id @default(uuid())
  agentId     String?
  title       String
  description String
  votes       Int                  @default(0)
  status      FeatureRequestStatus @default(open)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  agent       Agent?               @relation(fields: [agentId], references: [id])

  @@index([votes])
  @@index([status])
}

model TrackingEvent {
  id          String   @id
  orderId     String
  carrier     String
  status      String
  description String
  location    String?
  occurredAt  DateTime
  rawData     Json     @default("{}")
  createdAt   DateTime @default(now())

  order       Order    @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([carrier])
  @@index([occurredAt])
}

enum BuyOrderStatus {
  active
  paused
  fulfilled
  expired
}

model BuyOrder {
  id                  String         @id @default(uuid())
  agentId             String
  searchQuery         String
  maxPriceUsdc        BigInt
  category            String?
  condition           ListingCondition?
  minSellerReputation Float?
  autoBuy             Boolean        @default(false)
  autoBuyMaxUsdc      BigInt?
  status              BuyOrderStatus @default(active)
  matchedListingId    String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  expiresAt           DateTime?

  agent               Agent          @relation(fields: [agentId], references: [id])
  matchedListing      Listing?       @relation("MatchedListing", fields: [matchedListingId], references: [id])

  @@index([agentId])
  @@index([status])
}

// ─── Phase 3: Marketplace Integration ─────────────────────────────

model MarketplaceCredential {
  id                 String   @id @default(uuid())
  agentId            String
  marketplace        String   // "ebay", "mercari", etc.
  encryptedTokens    String   // AES-256-GCM encrypted JSON blob
  metadata           Json     @default("{}") // e.g. { "ebayUsername": "...", "sandbox": true }
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  agent              Agent    @relation(fields: [agentId], references: [id])

  @@unique([agentId, marketplace])
  @@index([agentId])
  @@index([marketplace])
}

// ─── Phase 4: Dispute Resolution ───────────────────────────────────────

enum DisputeStatus {
  open
  evidence_review
  resolved
}

enum DisputeReason {
  not_received
  wrong_item
  damaged
  counterfeit
  not_as_described
  other
}

enum DisputeResolution {
  full_refund
  partial_refund
  release_to_seller
  split
}

model Dispute {
  id            String             @id @default(uuid())
  orderId       String             @unique
  openedById    String
  reason        DisputeReason
  description   String
  status        DisputeStatus      @default(open)
  resolution    DisputeResolution?
  resolvedById  String?
  resolvedAt    DateTime?
  resolutionNotes String?
  refundAmount  BigInt?
  disputeTxSignature String?
  resolutionTxSignature String?
  evidenceDeadline DateTime?
  flaggedAt     DateTime?
  flagReason    String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  order         Order              @relation(fields: [orderId], references: [id])
  openedBy      Agent              @relation("DisputeOpener", fields: [openedById], references: [id])
  resolvedBy    Agent?             @relation("DisputeResolver", fields: [resolvedById], references: [id])
  evidence      DisputeEvidence[]

  @@index([orderId])
  @@index([status])
  @@index([openedById])
}

model DisputeEvidence {
  id          String   @id @default(uuid())
  disputeId   String
  submittedById String
  description String
  urls        String[]
  type        String   @default("other") // photo, screenshot, receipt, communication, other
  createdAt   DateTime @default(now())

  dispute     Dispute  @relation(fields: [disputeId], references: [id])
  submittedBy Agent    @relation("EvidenceSubmitter", fields: [submittedById], references: [id])

  @@index([disputeId])
  @@index([submittedById])
}

model SyndicationRecord {
  id                 String   @id @default(uuid())
  listingId          String
  marketplace        String   // "ebay"
  externalId         String   // eBay listing ID
  externalUrl        String
  status             String   @default("active") // active, ended, error
  lastSyncedAt       DateTime @default(now())
  metadata           Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  listing            Listing  @relation(fields: [listingId], references: [id])

  @@unique([listingId, marketplace])
  @@index([listingId])
  @@index([marketplace])
  @@index([externalId])
}

// ─── Phase 5: Agent Negotiation Protocol ───────────────────────────────

model Negotiation {
  id              String               @id @default(uuid())
  listingId       String
  listing         Listing              @relation(fields: [listingId], references: [id])
  buyerAgentId    String
  buyerAgent      Agent                @relation("NegotiationBuyer", fields: [buyerAgentId], references: [id])
  sellerAgentId   String
  sellerAgent     Agent                @relation("NegotiationSeller", fields: [sellerAgentId], references: [id])
  status          String               @default("active") // active, accepted, rejected, withdrawn, expired
  currentPrice    Int?                 // Latest offered price (USDC minor units)
  messages        NegotiationMessage[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  expiresAt       DateTime?

  @@index([listingId])
  @@index([buyerAgentId])
  @@index([sellerAgentId])
  @@index([status])
}

model NegotiationMessage {
  id              String      @id @default(uuid())
  negotiationId   String
  negotiation     Negotiation @relation(fields: [negotiationId], references: [id])
  fromAgentId     String
  fromAgent       Agent       @relation(fields: [fromAgentId], references: [id])
  type            String      // OFFER, COUNTER, ACCEPT, REJECT, CLARIFY, INSPECT, ESCALATE_TO_HUMAN, WITHDRAW
  payload         Json        // Type-specific payload
  createdAt       DateTime    @default(now())

  @@index([negotiationId])
  @@index([fromAgentId])
}

// ─── Phase 6: The Purse — Programmable Spending Policies ───────────────

model SpendingPolicy {
  id                  String   @id @default(uuid())
  agentId             String   @unique
  agent               Agent    @relation(fields: [agentId], references: [id])
  monthlyLimitUsdc    Int?     // Monthly spending cap (USDC minor units, null = unlimited)
  perTransactionMax   Int?     // Max per single transaction
  autoApproveBelow    Int?     // Auto-approve purchases below this amount
  requireHumanAbove   Int?     // Must get human approval above this
  allowedCategories   String[] // Empty = all categories allowed
  blockedSellers      String[] // Agent IDs to never buy from
  cooldownMinutes     Int?     // Min time between purchases
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ─── Phase 7: Event Notifications ──────────────────────────────────────

model Event {
  id        String   @id @default(uuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id])
  type      String   // order.created, order.shipped, order.delivered, dispute.opened, negotiation.offer, etc.
  title     String   // "New order for GMK Keycaps"
  message   String   // "A buyer purchased your listing for $75.00"
  data      Json?    // { orderId, listingId, etc. }
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([agentId, read])
  @@index([agentId, type])
  @@index([createdAt])
}

// ─── Phase 8: Settlement Wallets ───────────────────────────────────────

enum WalletRole {
  operational
  escrow_release
  escrow_refund
}

model UserWallet {
  id                 String     @id @default(uuid())
  agentId            String
  role               WalletRole
  address            String     // Solana pubkey
  activatedAt        DateTime   @default(now())
  changeEffectiveAt  DateTime?  // null = active now; set to now()+24h on change request
  changeLockedUntil  DateTime?  // prevents rapid changes
  pendingAddress     String?    // new address waiting for 24h delay
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  agent              Agent      @relation(fields: [agentId], references: [id])

  @@unique([agentId, role])
  @@index([agentId])
}
